# === Server ===
NODE_ENV=development
PORT=5000

# === MongoDB Atlas ===
# Remplace avec ta chaîne de connexion Atlas :
# Exemple : mongodb+srv://user:password@cluster.xxxxx.mongodb.net/mediflow?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/mediflow?retryWrites=true&w=majority

# === JWT ===
# Génère 2 chaînes aléatoires de 64+ caractères (voir README)
JWT_ACCESS_SECRET=change_me_to_a_long_random_string_64_chars_minimum
JWT_REFRESH_SECRET=change_me_to_another_long_random_string_64_chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# === CORS ===
CLIENT_URL=http://localhost:5173

# === Rate limit ===
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
